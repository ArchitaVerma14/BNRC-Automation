{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "typeRoots": ["./types", "./node_modules/@types"],


    "baseUrl": "./",

    "resolveJsonModule": true,
    "moduleDetection": "force",

    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "types": ["node"]
  },
  "include": ["**/*.ts"]
}
